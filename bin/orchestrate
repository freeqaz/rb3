#!/usr/bin/env python3
"""RB3 Decomp Orchestrator - CLI entry point.

Usage:
    bin/orchestrate ingest          # Ingest report.json into database
    bin/orchestrate query           # Query workable functions
    bin/orchestrate stats           # Show database statistics
    bin/orchestrate mcp             # Run MCP server (used by .mcp.json)
"""

import argparse
import json
import sys
from pathlib import Path

# Add project root to path
project_root = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(project_root))

from scripts.orchestrator.database import (
    init_database,
    ingest_report,
    query_functions,
    get_stats,
    DEFAULT_DB_PATH,
)


def cmd_ingest(args):
    """Ingest report.json into the database."""
    report_path = project_root / "build" / "SZBE69_B8" / "report.json"
    if not report_path.exists():
        print(f"Error: report.json not found at {report_path}")
        print("Run 'ninja' first to generate it.")
        sys.exit(1)

    db_path = args.db or DEFAULT_DB_PATH
    result = ingest_report(report_path, db_path=db_path)
    print(f"Ingested: {result['inserted']} new, {result['updated']} updated, {result['skipped']} skipped")

    stats = get_stats(db_path=db_path)
    print(f"\nDatabase stats:")
    print(f"  Total functions: {stats['total_functions']}")
    print(f"  Complete: {stats['complete']}")
    print(f"  At limit: {stats['at_limit']}")
    print(f"  Average match: {stats['avg_percent']:.1f}%")


def cmd_query(args):
    """Query functions from the database."""
    db_path = args.db or DEFAULT_DB_PATH

    pattern = args.pattern or "*"
    status = args.status or "workable"

    if status == "all":
        exclude_complete = False
        exclude_at_limit = False
        verdict_filter = None
    elif status == "complete":
        exclude_complete = False
        exclude_at_limit = True
        verdict_filter = "COMPLETE"
    elif status == "at_limit":
        exclude_complete = True
        exclude_at_limit = False
        verdict_filter = "AT_LIMIT"
    else:
        exclude_complete = True
        exclude_at_limit = True
        verdict_filter = None

    results = query_functions(
        pattern=pattern,
        min_percent=args.min_pct or 0,
        max_percent=args.max_pct or 100,
        exclude_complete=exclude_complete,
        exclude_at_limit=exclude_at_limit,
        verdict_filter=verdict_filter,
        limit=args.limit or 20,
        db_path=db_path,
    )

    if not results:
        print("No functions found matching criteria.")
        return

    print(f"Found {len(results)} functions:\n")
    for func in results:
        pct = func.get("current_percent")
        pct_str = f"{pct:.1f}%" if pct is not None else "N/A"
        verdict = func.get("verdict", "")
        v_str = f" [{verdict}]" if verdict else ""
        demangled = func.get("demangled", "")
        print(f"  {pct_str:>7s}{v_str:>12s}  {func['symbol']}")
        if demangled:
            print(f"{'':>20s}  ({demangled})")


def cmd_stats(args):
    """Show database statistics."""
    db_path = args.db or DEFAULT_DB_PATH
    try:
        stats = get_stats(db_path=db_path)
    except Exception as e:
        print(f"Error: {e}")
        print("Run 'bin/orchestrate ingest' first to create the database.")
        sys.exit(1)

    print(f"RB3 Decomp Database Statistics")
    print(f"{'='*40}")
    print(f"Total functions:  {stats['total_functions']}")
    print(f"Complete (100%):  {stats['complete']}")
    print(f"At limit:         {stats['at_limit']}")
    print(f"Average match:    {stats['avg_percent']:.1f}%")
    print(f"Total attempts:   {stats['total_attempts']}")


def cmd_mcp(args):
    """Run the MCP server."""
    import asyncio
    from scripts.orchestrator.mcp_server import DecompMCPServer

    db_path = args.db or DEFAULT_DB_PATH
    server = DecompMCPServer(db_path=db_path)
    asyncio.run(server.run())


def main():
    parser = argparse.ArgumentParser(description="RB3 Decomp Orchestrator")
    parser.add_argument("--db", default=None, help="Database path (default: decomp.db)")

    subparsers = parser.add_subparsers(dest="command")

    # ingest
    sub = subparsers.add_parser("ingest", help="Ingest report.json into database")

    # query
    sub = subparsers.add_parser("query", help="Query workable functions")
    sub.add_argument("--pattern", "-p", help="Unit glob pattern (e.g., 'main/*')")
    sub.add_argument("--status", "-s", choices=["workable", "all", "complete", "at_limit"], default="workable")
    sub.add_argument("--min-pct", type=float, help="Minimum match percentage")
    sub.add_argument("--max-pct", type=float, help="Maximum match percentage")
    sub.add_argument("--limit", "-n", type=int, default=20, help="Max results")

    # stats
    sub = subparsers.add_parser("stats", help="Show database statistics")

    # mcp
    sub = subparsers.add_parser("mcp", help="Run MCP server")

    args = parser.parse_args()

    if args.command == "ingest":
        cmd_ingest(args)
    elif args.command == "query":
        cmd_query(args)
    elif args.command == "stats":
        cmd_stats(args)
    elif args.command == "mcp":
        cmd_mcp(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
